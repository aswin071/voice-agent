LIVEKIT_URL=wss://your-livekit-host
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

SARVAM_API_KEY=your_sarvam_api_key
SARVAM_STT_URL=https://api.sarvam.ai/speech-to-text
SARVAM_TTS_URL=https://api.sarvam.ai/text-to-speech
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_MODE=transcribe
SARVAM_STT_SAMPLE_RATE=16000
SARVAM_STT_HIGH_VAD_SENSITIVITY=true
SARVAM_STT_FLUSH_SIGNAL=true
SARVAM_STT_INPUT_AUDIO_CODEC=audio/wav
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_OUTPUT_AUDIO_CODEC=mp3
SARVAM_TTS_OUTPUT_AUDIO_BITRATE=128k
SARVAM_TTS_MIN_BUFFER_SIZE=50
SARVAM_TTS_MAX_CHUNK_LENGTH=150

ANTHROPIC_API_KEY=your_anthropic_api_key
LLM_MODEL=claude-haiku-4-5

DATABASE_URL=postgresql+asyncpg://speedcare:speedcare@localhost:5432/speedcare
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=replace-with-a-long-random-secret
SIP_OUTBOUND_TRUNK_ID=

# CORS — comma-separated list of your frontend/dashboard origins
ALLOWED_ORIGINS=https://app.speedcare.in,https://admin.speedcare.in

SMS_PROVIDER=exotel
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SID=
EXOTEL_SENDER_NUMBER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

SENTRY_DSN=
